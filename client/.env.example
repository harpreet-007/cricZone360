# For Cloudflare Pages, leave these unset.
# The app will use same-origin /api routes served by Pages Functions.
#
# Required Cloudflare Pages environment variable:
# CRIC_API_KEY=your_cricapi_key
#
# Optional only if you use a separate backend:
# NEXT_PUBLIC_API_URL=https://your-backend-api.example.com/api
# NEXT_PUBLIC_SOCKET_URL=https://your-backend-api.example.com
